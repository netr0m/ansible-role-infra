# {{ ansible_managed }}
services:
  {{ infra_homarr_service_name }}:
    image: {{ infra_homarr_container_image }}
    container_name: {{ infra_homarr_container_hostname }}
    hostname: {{ infra_homarr_container_hostname }}
    restart: {{ infra_homarr_restart_policy | default(infra_restart_policy) }}
    logging:
      driver: {{ svc_log_driver }}
      options: {{ svc_log_options }}
    env_file: {{ infra_homarr_env_file_path }}
    volumes:
      - {{ infra_homarr_volume_name_data }}:/appdata
    mem_limit: {{ infra_homarr_container_memory }}
    labels:
      traefik.enable: 'true'
      traefik.docker.network: {{ svc_docker_network_name }}
      traefik.http.routers.{{ infra_homarr_service_name }}-rtr.rule: "Host(\"{{ infra_homarr_fqdn }}\")"
      traefik.http.routers.{{ infra_homarr_service_name }}-rtr.entrypoints: webSecure
      traefik.http.services.{{ infra_homarr_service_name }}-svc.loadbalancer.server.port: 7575
      traefik.http.services.{{ infra_homarr_service_name }}-svc.loadbalancer.server.scheme: http
      traefik.http.routers.{{ infra_homarr_service_name }}-rtr.service: {{ infra_homarr_service_name }}-svc
      traefik.http.routers.{{ infra_homarr_service_name }}-rtr.middlewares: {{ infra_homarr_traefik_middlewares | join(',') }}
      docker-volume-backup.stop-during-backup: "{{ infra_homarr_service_name }}"
    networks:
      - {{ svc_docker_network_name }}
{% if infra_containers_override_dns %}
    dns: {{ infra_container_dns_servers }}
{% endif %}

volumes:
  {{ infra_homarr_volume_name_data }}:
    name: {{ infra_homarr_volume_name_data }}
    labels: {{ infra_homarr_volume_labels | combine(infra_docker_volume_shared_labels) }}

networks:
  {{ svc_docker_network_name }}:
    external: 'true'
